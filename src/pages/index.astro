---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Profile from '@/components/Profile.astro';
import Links from '@/components/Links.astro';
import LinkItem from '@/components/ui/LinkItem.astro';
import Featured from '@/components/Featured.astro';
import FeaturedItem from '@/components/ui/FeaturedItem.astro';
import Card from '@/components/ui/Card.astro';
import LinkButton from '@/components/ui/LinkButton.astro';
import { Icon } from 'astro-icon/components';

// Importamos el JSON de configuración
import data from '../data/config.json';

const { metadata, profile, sections } = data;
---

<BaseLayout metadata={metadata}>
  <Profile
    name={profile.name}
    username={profile.username}
    about={profile.about}
    statusText={profile.status.text}
    statusEmoji={profile.status.emoji}
    statusLink={profile.status.link}
    avatarSrc={profile.avatar}
    bannerSrc={profile.banner}
    badges={profile.badges.map(b => ({ label: b.label, colorClass: `${b.color} text-white` }))}
    stats={profile.stats}
  />

  {sections.map((section) => (
    <>
      {/* SECCIÓN DE ENLACES */}
      {section.type === 'links' && (
        <Links title={section.title}>
          {section.items.map((item) => (
            <LinkItem href={item.url} label={item.label}>
              <Icon name={item.icon} slot="icon" width="20" height="20" />
            </LinkItem>
          ))}
        </Links>
      )}

      {/* SECCIÓN DE DESTACADOS (GRID) */}
      {section.type === 'featured' && (
        <Featured title={section.title}>
          {section.items.map((item) => (
            <FeaturedItem 
              href={item.url} 
              title={item.title} 
              imageSrc={`${item.image}?auto=format&fit=crop&w=400&h=400&q=80`} 
              altText={item.title} 
            />
          ))}
        </Featured>
      )}

      {/* SECCIÓN DE VIDEO/MEDIA */}
      {section.type === 'media' && (
        <Card title={section.title}>
          <iframe
            width="100%"
            height="315"
            src={section.embedUrl}
            title={section.title}
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            allowfullscreen
            class="rounded-radius"
          ></iframe>
        </Card>
      )}

      {/* SECCIÓN DE CONTACTO/MAPA */}
      {section.type === 'contact' && (
        <Card title={section.title}>
          <img
            src={section.mapImage}
            alt="Ubicación"
            class="size-full max-w-full rounded-radius object-cover shadow-md"
          />
          <LinkButton href={`mailto:${section.email}`} text={section.buttonText} isEmail={true} />
        </Card>
      )}
    </>
  ))}
</BaseLayout>
